{
  "name": "librawspeed-full",
  "version": "1.0.130",
  "description": "Node.js Native Addon for LibRaw - Process RAW image files with JavaScript",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "download": "bash scripts/download-dependencies.sh",
    "build-libraw": "bash scripts/build-libraw.sh",
    "prepare-libraw": "node scripts/prepare-libraw.js",
    "build": "npm run prepare-libraw && node-gyp rebuild",
    "rebuild": "npm run clean && npm run build",
    "prebuildify": "prebuildify --napi",
    "prebuildify:all": "prebuildify --napi --target 18.0.0 --target 20.0.0 --target 22.0.0 --target 24.0.0",
    "build:all": "npm run prebuildify:all",
    "verify:release-prebuilds": "node scripts/verify-release-prebuilds.js",
    "test": "node test/index.js",
    "test:packaging": "node test/packaging.test.js",
    "test:quick": "node test/index.js quick",
    "test:comprehensive": "node test/comprehensive.test.js",
    "prepublishOnly": "npm run test && npm run verify:release-prebuilds",
    "install": "node-gyp-build \"node scripts/prepare-libraw.js\"",
    "clean": "node-gyp clean",
    "docs:generate": "node scripts/generate-docs.js",
    "release": "bumpp && git push --follow-tags",
    "release:patch": "bumpp patch && git push --follow-tags",
    "release:minor": "bumpp minor && git push --follow-tags",
    "release:major": "bumpp major && git push --follow-tags"
  },
  "dependencies": {
    "chroma-js": "^3.1.2",
    "exiftool-vendored": "^30.5.0",
    "node-addon-api": "^7.1.1",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "bumpp": "^10.2.3",
    "node-gyp": "^10.0.0",
    "prebuildify": "^6.0.1",
    "sharp": "^0.33.5"
  },
  "peerDependencies": {
    "sharp": ">=0.33 <0.40"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "gypfile": true,
  "binary": {
    "module_name": "libraw_addon",
    "module_path": "./build/Release/",
    "napi_versions": [
      3,
      4,
      5,
      6,
      7,
      8,
      9,
      10
    ]
  },
  "napi": {
    "name": "librawspeed-full",
    "triples": {
      "defaults": true,
      "additional": [
        "x64-apple-darwin",
        "arm64-apple-darwin",
        "x64-pc-windows-msvc",
        "x64-unknown-linux-gnu"
      ]
    }
  },
  "files": [
    "lib/**/*",
    "prebuilds/**/*",
    "scripts/**/*",
    "src/**/*",
    "deps/LibRaw-Source/**/*",
    "types/**/*",
    "binding.gyp",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "keywords": [
    "libraw",
    "raw",
    "image",
    "photography",
    "native-addon",
    "nef",
    "cr2",
    "cr3",
    "arw",
    "dng",
    "raf",
    "rw2",
    "metadata",
    "exif",
    "canon",
    "nikon",
    "sony",
    "fujifilm",
    "panasonic",
    "leica",
    "adobe-dng",
    "jpeg",
    "jpeg-conversion",
    "image-conversion",
    "batch-processing",
    "sharp",
    "mozjpeg",
    "compression",
    "optimization",
    "resize",
    "quality"
  ],
  "author": "Bao LE <bao.lq.it@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bookyo/librawspeed-full.git"
  },
  "bugs": {
    "url": "https://github.com/bookyo/librawspeed-full/issues"
  },
  "homepage": "https://github.com/bookyo/librawspeed-full#readme"
}
